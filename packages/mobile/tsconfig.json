{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "strict": true,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@rr/shared": ["../shared/src/types.ts"],
      "@rr/shared/*": ["../shared/src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["app", "src", "*.ts", "*.tsx", "nativewind-env.d.ts"]
}
