{
  "expo": {
    "name": "ReducedRecipes",
    "slug": "reduced-recipes",
    "version": "1.0.0",
    "scheme": "reducedrecipes",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.reducedrecipes.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Used for voice-guided cooking instructions.",
        "NSUserNotificationUsageDescription": "Get notified when new recipes are added from your saved sites."
      },
      "associatedDomains": [
        "applinks:reducedrecipes.com",
        "webcredentials:reducedrecipes.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAF8"
      },
      "package": "com.reducedrecipes.app",
      "versionCode": 1,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "reducedrecipes.com",
              "pathPrefix": "/recipe/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E85D26"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 29
          }
        }
      ],
      "expo-secure-store"
    ],
    "owner": "nikrich",
    "extra": {
      "router": {
        "origin": "https://reducedrecipes.com"
      },
      "eas": {
        "projectId": "a9fcf4d9-1b31-4c70-8d2f-ed1b8952fe81"
      }
    }
  }
}
