{
  "expo": {
    "name": "ReducedRecipes",
    "slug": "reduced-recipes",
    "version": "1.0.0",
    "scheme": "reducedrecipes",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.reducedrecipes.app",
      "associatedDomains": [
        "applinks:reducedrecipes.com",
        "webcredentials:reducedrecipes.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAF8"
      },
      "package": "com.reducedrecipes.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "reducedrecipes.com",
              "pathPrefix": "/recipe/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "expo-keep-awake",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E85D26"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 29
          }
        }
      ]
    ],
    "updates": {
      "checkOnLaunch": "ALWAYS",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      },
      "router": {
        "origin": "https://reducedrecipes.com"
      }
    },
    "owner": "reducedrecipes"
  }
}
