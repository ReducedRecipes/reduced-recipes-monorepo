{
  "expo": {
    "name": "ReducedRecipes",
    "slug": "reducedrecipes",
    "version": "1.11.0",
    "scheme": "reducedrecipes",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3F0EB"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.reducedrecipes.app",
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Used for voice-guided cooking instructions.",
        "NSUserNotificationUsageDescription": "Get notified when new recipes are added from your saved sites."
      },
      "associatedDomains": [
        "applinks:reduced.recipes",
        "webcredentials:reduced.recipes"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F3F0EB"
      },
      "package": "com.reducedrecipes.app",
      "versionCode": 1,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "reduced.recipes",
              "pathPrefix": "/recipe/"
            },
            {
              "scheme": "https",
              "host": "reduced.recipes",
              "pathPrefix": "/shared/lists/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C45A30"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 29,
            "useLegacyPackaging": false
          }
        }
      ],
      "expo-secure-store"
    ],
    "owner": "reduced-recipes",
    "extra": {
      "router": {
        "origin": "https://reduced.recipes"
      },
      "eas": {
        "projectId": "b45c3076-b327-47bf-b371-4b85d75fd9b2"
      }
    }
  }
}
