{
  "name": "@rr/workers",
  "version": "1.5.0",
  "type": "module",
  "private": true,
  "dependencies": {
    "@rr/shared": "workspace:*",
    "hono": "^4.3",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512",
    "wrangler": "^3.50"
  },
  "scripts": {
    "deploy": "wrangler deploy -c wrangler.api.toml && wrangler deploy -c wrangler.orchestrator.toml && wrangler deploy -c wrangler.crawler.toml && wrangler deploy -c wrangler.parser.toml && wrangler deploy -c wrangler.projection.toml && wrangler deploy -c wrangler.dlq.toml && wrangler deploy -c wrangler.hot-refresh.toml && wrangler deploy -c wrangler.billing.toml && wrangler deploy -c wrangler.sitemap.toml",
    "deploy:billing": "wrangler deploy -c wrangler.billing.toml",
    "deploy:sitemap": "wrangler deploy -c wrangler.sitemap.toml",
    "deploy:api": "wrangler deploy -c wrangler.api.toml",
    "deploy:orchestrator": "wrangler deploy -c wrangler.orchestrator.toml",
    "deploy:crawler": "wrangler deploy -c wrangler.crawler.toml",
    "deploy:parser": "wrangler deploy -c wrangler.parser.toml",
    "deploy:projection": "wrangler deploy -c wrangler.projection.toml",
    "deploy:dlq": "wrangler deploy -c wrangler.dlq.toml",
    "deploy:hot-refresh": "wrangler deploy -c wrangler.hot-refresh.toml",
    "dev:api": "wrangler dev -c wrangler.api.toml",
    "dev:orchestrator": "wrangler dev -c wrangler.orchestrator.toml",
    "dev:crawler": "wrangler dev -c wrangler.crawler.toml",
    "dev:parser": "wrangler dev -c wrangler.parser.toml",
    "dev:projection": "wrangler dev -c wrangler.projection.toml",
    "dev:dlq": "wrangler dev -c wrangler.dlq.toml",
    "dev:hot-refresh": "wrangler dev -c wrangler.hot-refresh.toml",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  }
}
