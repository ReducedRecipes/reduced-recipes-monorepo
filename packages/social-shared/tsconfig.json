{
  "compilerOptions": {
    "target": "ES2022", "module": "ES2022", "moduleResolution": "bundler",
    "strict": true, "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types", "vitest/globals"],
    "esModuleInterop": true, "skipLibCheck": true, "noEmit": true,
    "declaration": false
  },
  "include": ["src/**/*.ts"]
}
